rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Primitives & Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    
    // -------------------------------------------------------------------------
    // Global Safety Net
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      // Preferences
      match /preferences/{prefId} {
        allow get: if isOwner(userId) && isValidId(prefId);
        allow list: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(prefId) 
          && incoming().keys().hasAll(['lastActive']);
        allow delete: if isOwner(userId) && isValidId(prefId);
      }

      // Memories
      match /memories/{memoryId} {
        allow get: if isOwner(userId) && isValidId(memoryId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(memoryId)
          && incoming().fact is string && incoming().fact.size() <= 1000
          && incoming().createdAt == request.time;
        allow update, delete: if isOwner(userId) && isValidId(memoryId);
      }

      // Messages
      match /messages/{messageId} {
        allow get: if isOwner(userId) && isValidId(messageId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(messageId)
          && incoming().role in ['user', 'model']
          && incoming().timestamp == request.time;
        allow update, delete: if isOwner(userId) && isValidId(messageId);
      }
    }
  }
}
